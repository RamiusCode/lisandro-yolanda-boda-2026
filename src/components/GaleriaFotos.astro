---
// src/components/Galeria.astro
---

<section class="py-4 px-4 relative overflow-hidden">
    <div class="max-w-sm sm:max-w-sm md:max-w-xl mx-auto relative z-10">
        <div class="flex flex-col gap-4">
            <!-- FOTO 1 - Ancho completo, alta para ver de arriba a abajo -->
            <div class="foto-card group cursor-pointer w-full" data-index="0">
                <div
                    class="relative overflow-hidden rounded-[1.5rem] w-full"
                    style="height: 320px;"
                >
                    <img
                        src="/imagenes/foto1.png"
                        alt="Momento 1"
                        class="w-full h-full object-cover object-top transform group-hover:scale-105 transition-transform duration-700"
                    />
                    <div
                        class="absolute inset-0 bg-black/10 group-hover:bg-black/20 transition-all duration-500"
                    >
                    </div>
                    <!-- Lupa -->
                    <div
                        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 transition-all duration-400"
                    >
                        <div
                            class="w-16 h-16 rounded-full bg-white/25 backdrop-blur-xl flex items-center justify-center border-2 border-white/40"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                stroke-linecap="round"
                            >
                                <circle
                                    cx="10.5"
                                    cy="10.5"
                                    r="6.5"
                                    stroke-width="2.5"></circle>
                                <path d="M15.5 15.5L21 21" stroke-width="2.5"
                                ></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FILA: FOTO 2 y FOTO 3 — misma altura -->
            <div class="flex gap-4">
                <!-- FOTO 2 -->
                <div
                    class="foto-card group cursor-pointer flex-1"
                    data-index="1"
                >
                    <div
                        class="relative overflow-hidden rounded-[1.5rem]"
                        style="height: 220px;"
                    >
                        <img
                            src="/imagenes/foto2.png"
                            alt="Momento 2"
                            class="w-full h-full object-cover object-top transform group-hover:scale-105 transition-transform duration-700"
                        />
                        <div
                            class="absolute inset-0 bg-black/10 group-hover:bg-black/20 transition-all duration-500"
                        >
                        </div>
                        <div
                            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 transition-all duration-400"
                        >
                            <div
                                class="w-14 h-14 rounded-full bg-white/25 backdrop-blur-xl flex items-center justify-center border-2 border-white/40"
                            >
                                <svg
                                    class="w-7 h-7 text-white"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    stroke-linecap="round"
                                >
                                    <circle
                                        cx="10.5"
                                        cy="10.5"
                                        r="6.5"
                                        stroke-width="2.5"></circle>
                                    <path
                                        d="M15.5 15.5L21 21"
                                        stroke-width="2.5"></path>
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- FOTO 3 -->
                <div
                    class="foto-card group cursor-pointer flex-1"
                    data-index="2"
                >
                    <div
                        class="relative overflow-hidden rounded-[1.5rem]"
                        style="height: 220px;"
                    >
                        <img
                            src="/imagenes/foto3.png"
                            alt="Momento 3"
                            class="w-full h-full object-cover object-top transform group-hover:scale-105 transition-transform duration-700"
                        />
                        <div
                            class="absolute inset-0 bg-black/10 group-hover:bg-black/20 transition-all duration-500"
                        >
                        </div>
                        <div
                            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 transition-all duration-400"
                        >
                            <div
                                class="w-14 h-14 rounded-full bg-white/25 backdrop-blur-xl flex items-center justify-center border-2 border-white/40"
                            >
                                <svg
                                    class="w-7 h-7 text-white"
                                    fill="none"
                                    stroke="currentColor"
                                    viewBox="0 0 24 24"
                                    stroke-linecap="round"
                                >
                                    <circle
                                        cx="10.5"
                                        cy="10.5"
                                        r="6.5"
                                        stroke-width="2.5"></circle>
                                    <path
                                        d="M15.5 15.5L21 21"
                                        stroke-width="2.5"></path>
                                </svg>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- FOTO 4 - Ancho completo igual que foto 1 -->
            <div class="foto-card group cursor-pointer w-full" data-index="3">
                <div
                    class="relative overflow-hidden rounded-[1.5rem] w-full"
                    style="height: 320px;"
                >
                    <img
                        src="/imagenes/foto4.png"
                        alt="Momento 4"
                        class="w-full h-full object-cover object-top transform group-hover:scale-105 transition-transform duration-700"
                    />
                    <div
                        class="absolute inset-0 bg-black/10 group-hover:bg-black/20 transition-all duration-500"
                    >
                    </div>
                    <div
                        class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 opacity-0 group-hover:opacity-100 scale-50 group-hover:scale-100 transition-all duration-400"
                    >
                        <div
                            class="w-16 h-16 rounded-full bg-white/25 backdrop-blur-xl flex items-center justify-center border-2 border-white/40"
                        >
                            <svg
                                class="w-8 h-8 text-white"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                stroke-linecap="round"
                            >
                                <circle
                                    cx="10.5"
                                    cy="10.5"
                                    r="6.5"
                                    stroke-width="2.5"></circle>
                                <path d="M15.5 15.5L21 21" stroke-width="2.5"
                                ></path>
                            </svg>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- MODAL CON CARRUSEL -->
    <div
        id="modal-galeria"
        class="fixed inset-0 bg-black/97 backdrop-blur-3xl z-50 hidden items-center justify-center"
    >
        <button
            id="cerrar-modal"
            class="absolute top-6 right-6 w-14 h-14 rounded-full bg-white/10 hover:bg-white/20 backdrop-blur-2xl flex items-center justify-center transition-all duration-300 z-50 border border-white/20 hover:rotate-90"
        >
            <svg
                class="w-6 h-6 text-white"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
            >
                <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M6 18L18 6M6 6l12 12"></path>
            </svg>
        </button>

        <div
            class="relative w-full h-full flex items-center justify-center px-2 md:px-16"
        >
            <button
                id="btn-anterior"
                class="absolute left-4 md:left-8 w-14 h-14 rounded-full bg-white/10 hover:bg-[#ebccc4]/30 backdrop-blur-2xl flex items-center justify-center transition-all duration-300 z-40 border border-white/20 hover:scale-110"
            >
                <svg
                    class="w-7 h-7 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M15 19l-7-7 7-7"></path>
                </svg>
            </button>

            <div
                class="relative max-w-5xl w-full overflow-hidden"
                id="modal-contenido"
            >
                <div
                    id="carrusel-track"
                    class="flex transition-transform duration-700 ease-out"
                >
                </div>
                <div class="absolute bottom-6 left-1/2 -translate-x-1/2 z-30">
                    <div
                        class="bg-white/10 backdrop-blur-2xl px-8 py-4 rounded-full border border-white/20 shadow-2xl flex items-center gap-4"
                    >
                        <span
                            id="numero-actual"
                            class="text-white font-cathylise text-2xl">1</span
                        >
                        <div class="w-px h-8 bg-white/30"></div>
                        <span class="text-white/60 font-cathylise text-xl"
                            >4</span
                        >
                    </div>
                </div>
            </div>

            <button
                id="btn-siguiente"
                class="absolute right-4 md:right-8 w-14 h-14 rounded-full bg-white/10 hover:bg-[#ebccc4]/30 backdrop-blur-2xl flex items-center justify-center transition-all duration-300 z-40 border border-white/20 hover:scale-110"
            >
                <svg
                    class="w-7 h-7 text-white"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2.5"
                        d="M9 5l7 7-7 7"></path>
                </svg>
            </button>
        </div>
    </div>
</section>

<script>
    import { gsap } from "gsap";
    import { ScrollTrigger } from "gsap/ScrollTrigger";

    gsap.registerPlugin(ScrollTrigger);

    if (typeof window !== "undefined") {
        document.addEventListener("DOMContentLoaded", () => {
            gsap.set(".foto-card", { opacity: 0, y: 40 });

            ScrollTrigger.create({
                trigger: ".foto-card",
                start: "top 100%",
                toggleActions: "play none none reverse",
                animation: gsap.to(".foto-card", {
                    opacity: 1,
                    y: 0,
                    duration: 0.9,
                    stagger: { amount: 0.5, from: "start" },
                    ease: "power3.out",
                    paused: true,
                }),
            });

            const fotos = [
                { src: "/imagenes/foto1.png" },
                { src: "/imagenes/foto2.png" },
                { src: "/imagenes/foto3.png" },
                { src: "/imagenes/foto4.png" },
            ];

            let indiceActual = 0;
            const modal = document.getElementById("modal-galeria");
            const carruselTrack = document.getElementById("carrusel-track");
            const numeroActual = document.getElementById("numero-actual");
            const btnAnterior = document.getElementById("btn-anterior");
            const btnSiguiente = document.getElementById("btn-siguiente");
            const cerrarModal = document.getElementById("cerrar-modal");

            if (carruselTrack) {
                fotos.forEach((foto) => {
                    const slide = document.createElement("div");
                    slide.className =
                        "min-w-full flex items-center justify-center px-4 md:px-12";
                    slide.innerHTML = `
            <div class="relative max-w-5xl w-full">
              <div class="relative rounded-3xl overflow-hidden border-2 border-white/10 shadow-2xl">
                <img src="${foto.src}" class="w-full h-auto max-h-[80vh] object-contain bg-black/20"/>
              </div>
            </div>
          `;
                    carruselTrack.appendChild(slide);
                });
            }

            const actualizarCarrusel = (
                nuevo: number,
                animacion: boolean = true,
            ) => {
                if (!carruselTrack) return;
                indiceActual = (nuevo + fotos.length) % fotos.length;
                const d = -indiceActual * 100;
                if (animacion) {
                    gsap.to(carruselTrack, {
                        x: `${d}%`,
                        duration: 0.7,
                        ease: "power3.out",
                    });
                } else {
                    gsap.set(carruselTrack, { x: `${d}%` });
                }
                if (numeroActual)
                    numeroActual.textContent = (indiceActual + 1).toString();
            };

            const abrirModal = (indice: number) => {
                if (!modal) return;
                modal.classList.remove("hidden");
                modal.classList.add("flex");
                document.body.style.overflow = "hidden";
                actualizarCarrusel(indice, false);
                gsap.fromTo(
                    modal,
                    { opacity: 0 },
                    { opacity: 1, duration: 0.4, ease: "power2.out" },
                );
                gsap.fromTo(
                    "#modal-contenido",
                    { scale: 0.9, opacity: 0 },
                    {
                        scale: 1,
                        opacity: 1,
                        duration: 0.5,
                        ease: "power3.out",
                        delay: 0.1,
                    },
                );
            };

            const cerrarModalFn = () => {
                if (!modal) return;
                gsap.to(modal, {
                    opacity: 0,
                    duration: 0.3,
                    ease: "power2.in",
                    onComplete: () => {
                        modal.classList.add("hidden");
                        modal.classList.remove("flex");
                        document.body.style.overflow = "";
                    },
                });
            };

            document.querySelectorAll(".foto-card").forEach((card) => {
                card.addEventListener("click", () => {
                    abrirModal(
                        parseInt(card.getAttribute("data-index") || "0"),
                    );
                });
            });

            btnAnterior?.addEventListener("click", (e) => {
                e.stopPropagation();
                actualizarCarrusel(indiceActual - 1);
            });
            btnSiguiente?.addEventListener("click", (e) => {
                e.stopPropagation();
                actualizarCarrusel(indiceActual + 1);
            });
            cerrarModal?.addEventListener("click", (e) => {
                e.stopPropagation();
                cerrarModalFn();
            });
            modal?.addEventListener("click", (e) => {
                if (e.target === modal) cerrarModalFn();
            });

            document.addEventListener("keydown", (e) => {
                if (modal && !modal.classList.contains("hidden")) {
                    if (e.key === "Escape") cerrarModalFn();
                    if (e.key === "ArrowLeft")
                        actualizarCarrusel(indiceActual - 1);
                    if (e.key === "ArrowRight")
                        actualizarCarrusel(indiceActual + 1);
                }
            });

            let touchStartX = 0;
            modal?.addEventListener(
                "touchstart",
                (e) => {
                    touchStartX = e.touches[0].clientX;
                },
                { passive: true },
            );
            modal?.addEventListener("touchend", (e) => {
                const diff = touchStartX - e.changedTouches[0].clientX;
                if (Math.abs(diff) > 60)
                    actualizarCarrusel(
                        diff > 0 ? indiceActual + 1 : indiceActual - 1,
                    );
            });
        });
    }
</script>

<style>
    .foto-card {
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .foto-card:hover {
        transform: translateY(-6px);
        box-shadow: 0 20px 40px -10px rgba(235, 204, 196, 0.3);
    }
    #carrusel-track {
        will-change: transform;
    }
</style>
